generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model GalleryImage {
  id              Int      @id @default(autoincrement())
  url             String
  altText         String?
  seoTitle        String?
  metaDescription String?
  focusKeyword    String?
  canonicalUrl    String?
  ogImage         String?
  robots          String?
  schemaType      String?  @default("ImageObject")
  createdAt       DateTime @default(now())
}

model Timing {
  id          Int      @id @default(autoincrement())
  title       String
  time        String
  description String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
}

model Aarti {
  id              Int      @id @default(autoincrement())
  title           String
  audioUrl        String
  seoTitle        String?
  metaDescription String?
  focusKeyword    String?
  canonicalUrl    String?
  ogImage         String?
  robots          String?
  schemaType      String?  @default("MusicRecording")
  createdAt       DateTime @default(now())
}

model Guideline {
  id         Int      @id @default(autoincrement())
  text       String
  orderIndex Int      @default(0)
}

model Notice {
  id              Int      @id @default(autoincrement())
  title           String
  subtitle        String?
  date            DateTime?
  seoTitle        String?
  metaDescription String?
  focusKeyword    String?
  canonicalUrl    String?
  ogImage         String?
  robots          String?
  schemaType      String?  @default("NewsArticle")
  createdAt       DateTime @default(now())
}

model Event {
  id              Int      @id @default(autoincrement())
  title           String
  date            DateTime
  description     String?
  seoTitle        String?
  metaDescription String?
  focusKeyword    String?
  canonicalUrl    String?
  ogImage         String?
  robots          String?
  schemaType      String?  @default("Event")
  createdAt       DateTime @default(now())
}

model Expense {
  id            Int      @id @default(autoincrement())
  date          DateTime
  category      String
  amount        Float
  remark        String?
  familyMembers Int?     @default(1)
  createdAt     DateTime @default(now())
}

model Transaction {
  id          Int      @id @default(autoincrement())
  date        DateTime
  amount      Float
  type        String   // e.g., "DONATION", "MAINTENANCE"
  description String?
  createdAt   DateTime @default(now())
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Donor {
  id            Int      @id @default(autoincrement())
  name          String
  amount        Float
  date          DateTime
  note          String?
  familyMembers Int?     @default(1)
  createdAt     DateTime @default(now())
}

model HeroBackground {
  id        Int      @id @default(autoincrement())
  url       String
  mobileUrl String?
  tabletUrl String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id          Int      @id @default(autoincrement())
  heroTitle   String   @default("Hanuman Mandir")
  heroSubtitle String  @default("हनुमान मंदिर")
  heroQuote   String   @default("ॐ जय बजरंग बली ॐ")
  heroLocation String  @default("दरेकरवाडी, ढवळपुरी, पारनेर, अहिल्यानगर")
  aboutImage  String?
  qrImageUrl  String?
  ogImageUrl  String?
  donorsPdfUrl String?
  sevaPdfUrl   String?
  whatsappNumber  String?  @default("919999999999")
  whatsappMessage String?  @default("🙏 Jai Hanuman!\n\nI have completed my donation.\nPlease find my payment screenshot attached.\n\nThank you.")
  updatedAt   DateTime @updatedAt
}

model ThemeSettings {
  id              Int      @id @default(autoincrement())
  primaryColor    String   @default("#ea580c") // orange-600
  secondaryColor  String   @default("#d97706") // amber-600
  backgroundColor String   @default("#0f0805") // dark warm
  textColor       String   @default("#ffffff")
  updatedAt       DateTime @updatedAt
}

model AnimationSettings {
  id               Int      @id @default(autoincrement())
  enableAnimations Boolean  @default(true)
  speedMultiplier  Float    @default(1.0)
  enableParticles  Boolean  @default(true)
  enableFlowers    Boolean  @default(true)
  enableFog        Boolean  @default(true)
  enableParallax   Boolean  @default(true)
  enableGlow       Boolean  @default(true)
  enableLeaves     Boolean  @default(false)
  enableSmoke      Boolean  @default(false)
  enableSparkles   Boolean  @default(false)
  intensityMultiplier Float   @default(1.0)
  updatedAt        DateTime @updatedAt
}

model SeoSettings {
  id              Int      @id @default(autoincrement())
  metaTitle       String   @default("Hanuman Mandir Darekarwadi")
  metaDescription String   @default("Welcome to Hanuman Mandir, Darekarwadi")
  keywords        String   @default("hanuman, mandir, temple, darekarwadi")
  focusKeyword    String?
  canonicalUrl    String?
  ogImage         String?
  robots          String?
  schemaType      String?  @default("HinduTemple")
  updatedAt       DateTime @updatedAt
}

model Document {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  year      Int?
  type      String   // "DONOR" or "SEVA"
  createdAt DateTime @default(now())
}

model PaymentMethod {
  id          Int      @id @default(autoincrement())
  upiId       String   @unique
  payeeName   String?
  paymentNote String?
  qrImageUrl  String?
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BalanceEntry {
  id        Int      @id @default(autoincrement())
  year      Int      // e.g. 2024
  amount    Float    // can be positive, zero, or negative
  note      String?
  createdAt DateTime @default(now())
}

model MahaprasadItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  date        DateTime?
  startTime   String?
  endTime     String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
}

model Paharekari {
  id          Int      @id @default(autoincrement())
  date        DateTime?
  name        String
  startTime   String?
  endTime     String?
  createdAt   DateTime @default(now())
}
